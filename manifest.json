{
  "manifest_version": 3,
  "name": "Fix Gemini Parser",
  "version": "4.1",
  "description": "Enhance your Google Gemini experience with proper markdown and LaTeX rendering.",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon_16.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Fix Parser Settings",
    "default_icon": "icons/icon_48.png"
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["lib/katex.min.js", "content.js"],
      "css": ["lib/katex.min.css"]
    }
  ]
}
